{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ZusWaveBench item",
  "type": "object",
  "required": ["id", "domain", "task_type", "difficulty", "weight", "input", "expected"],
  "additionalProperties": false,
  "properties": {
    "id": {"type": "string", "pattern": "^PL-[A-Z]+-[0-9]{3}$"},
    "domain": {"type": "string"},
    "task_type": {
      "type": "string",
      "enum": [
        "document_classification",
        "remedy_selection",
        "term_disambiguation",
        "form_symbol_extraction",
        "organ_competence",
        "abbreviation_expansion",
        "deadline_reasoning",
        "style_transformation"
      ]
    },
    "difficulty": {"type": "integer", "minimum": 1, "maximum": 5},
    "weight": {"type": "number", "exclusiveMinimum": 0},
    "input": {"type": "string", "minLength": 10},
    "expected": {
      "type": "object",
      "required": ["labels", "required_concepts", "forbidden_claims", "notes"],
      "additionalProperties": false,
      "properties": {
        "labels": {"type": "object"},
        "required_concepts": {"type": "array", "items": {"type": "string"}},
        "forbidden_claims": {"type": "array", "items": {"type": "string"}},
        "notes": {"type": "string"}
      }
    },
    "sources": {"type": "array", "items": {"type": "string"}}
  }
}
